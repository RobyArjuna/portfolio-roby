REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-public-anon-key
REACT_APP_AI_DEBUG=false

# Server-side only. Set these as Supabase Edge Function secrets, not in the CRA frontend.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.5-flash
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional generation provider switch for Supabase Edge Function.
AI_GENERATION_PROVIDER=gemini
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=google/gemini-3.5-flash
OPENROUTER_SITE_URL=https://portfolio-robyarjuna.my.id
OPENROUTER_APP_TITLE=Roby Portfolio AI Assistant

# Optional ingestion overrides.
CV_PATH=src/asset/RobyCV.pdf
CHUNK_SIZE=700
CHUNK_OVERLAP=100
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_EMBEDDING_DIMENSIONS=768
